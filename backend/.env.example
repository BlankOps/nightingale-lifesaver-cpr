# Database Configuration (AWS RDS)
DB_HOST=your-db-host
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=app_admin
DB_PASSWORD=your-db-password
DB_SSL=true

# Chatbot Configuration
CHATBOT_IP=your-chatbot-host:5005
CHATBOT_API_URL=http://${CHATBOT_IP}/webhooks/rest/webhook
RASA_PORT=5005

# API Configuration
API_PORT=3000
NODE_ENV=production
