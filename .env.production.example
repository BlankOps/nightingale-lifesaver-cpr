# Production environment variables for Docker build
# These values are passed as --build-arg during docker build
# See PRODUCTION_DEPLOYMENT.md for build instructions

DB_HOST=your-production-db-host
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=app_admin
DB_PASSWORD=your-production-db-password
DB_SSL=true

CHATBOT_IP=your-chatbot-host:5005
CHATBOT_API_URL=http://${CHATBOT_IP}/webhooks/rest/webhook
RASA_PORT=5005

API_PORT=3000
NODE_ENV=production
