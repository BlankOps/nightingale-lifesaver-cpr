# Docker ignore patterns - speeds up build context
# ================================================

# Git files
.git
.gitignore
.gitattributes

# Development files
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Python
__pycache__
*.pyc
*.pyo
*.egg-info
.pytest_cache
.mypy_cache
venv/
env/
rasa310_env/
*.egg

# Node modules (local - will reinstall in container)
node_modules
npm-debug.log
yarn-error.log

# Documentation
*.md
README.md
PRODUCTION_DEPLOYMENT.md
docs/

# CI/CD
.github
.gitlab-ci.yml
.circleci

# Test files and results (optional)
tests/
test_*.py
results/
*.log

# Environment files (local dev only)
.env.local
.env.*.local

# Build outputs
build/
dist/
*.tar.gz
.next/
out/

# Cache
.cache
tmp/
temp/

# OS files
Thumbs.db
.DS_Store

# Docker files (optional - include if doing multi-build)
docker-compose.yml
docker-compose.*.yml
Dockerfile.*
